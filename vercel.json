{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api"
    },
    {
      "source": "/sitemap.xml",
      "destination": "/api?sitemap=true"
    },
    {
      "source": "/robots.txt",
      "destination": "/api?robots=true"
    },
    {
      "source": "/llms.txt",
      "destination": "/api?llms=true"
    },
    {
      "source": "/((?!assets/|favicon|.*\\..*).*)",
      "destination": "/api"
    }
  ]
}
